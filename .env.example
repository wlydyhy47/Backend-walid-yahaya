# ============================================
# FOOD DELIVERY BACKEND - ENVIRONMENT VARIABLES
# الإصدار: 2.0 (محدث)
# ============================================

# 🚀 SERVER CONFIGURATION
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
CLIENT_URL=http://localhost:3001
APP_NAME="Food Delivery"
CORS_ORIGIN=http://localhost:3001

# 📦 DATABASE CONFIGURATION
MONGO_URI=mongodb://localhost:27017/food_delivery
MONGO_URI_TEST=mongodb://localhost:27017/food_delivery_test

# 🔐 JWT AUTHENTICATION
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d
JWT_ALGORITHM=HS256
REQUIRE_VERIFICATION=true

# ☁️ CLOUDINARY FILE UPLOAD
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ⚡ CACHE & REDIS CONFIGURATION
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_ENABLED=true
CACHE_TTL=300

# 📝 LOGGING
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_DIR=logs

# 🛡️ RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_LOGIN_ATTEMPTS=10
LOCKOUT_TIME=3600000

# 🛡️ SECURITY
HELMET_ENABLED=true
XSS_PROTECTION=true
NOSQL_INJECTION_PROTECTION=true
PASSWORD_MIN_SCORE=4

# 📧 EMAIL SERVICE
EMAIL_ENABLED=false
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@fooddelivery.com

# 📱 SMS SERVICE
SMS_ENABLED=false
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# 🔔 PUSH NOTIFICATIONS
FCM_SERVER_KEY=your-fcm-server-key
APN_KEY_ID=your-apn-key-id
APN_TEAM_ID=your-apn-team-id
APN_KEY_PATH=path/to/apn/key.p8

# 💰 PAYMENT GATEWAY
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret

# 📊 ANALYTICS
GOOGLE_ANALYTICS_ID=your-ga-id
MIXPANEL_TOKEN=your-mixpanel-token

# ⚙️ PERFORMANCE
REQUEST_SIZE_LIMIT=10mb
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6

# 🧪 TESTING
TEST_TIMEOUT=30000
JEST_TIMEOUT=30000

# 🔧 FEATURE FLAGS
ENABLE_LOYALTY_PROGRAM=true
ENABLE_DRIVER_TRACKING=true
ENABLE_CHAT=true
ENABLE_PUSH_NOTIFICATIONS=true

# 🌍 INTERNATIONALIZATION
DEFAULT_LANGUAGE=ar
DEFAULT_CURRENCY=XOF
SUPPORTED_LANGUAGES=ar,fr,en
SUPPORTED_CURRENCIES=XOF,EUR,USD

# ============================================
# DEVELOPMENT SPECIFIC
# ============================================
# NODE_ENV=development
# DEBUG=true
# LOG_LEVEL=debug
# CACHE_TTL=60

# ============================================
# PRODUCTION SPECIFIC
# ============================================
# NODE_ENV=production
# DEBUG=false
# LOG_LEVEL=warn
# CACHE_TTL=600
# COMPRESSION_LEVEL=9