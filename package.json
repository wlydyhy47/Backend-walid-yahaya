{
  "name": "backend",
  "version": "1.0.0",
  "description": "Food Delivery Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:connection": "jest tests/01_connection.test.js --runInBand --forceExit",
    "test:health": "jest tests/01_health.test.js --runInBand --forceExit",
    "test:win": "set NODE_ENV=test&& jest --runInBand --detectOpenHandles --forceExit",
    "test:connection:win": "set NODE_ENV=test&& jest tests/01_connection.test.js --runInBand --forceExit",
    "migrate": "node src/migrations/migrate.js",
    "migrate:status": "node src/migrations/migrate.js --status",
    "rollback": "node src/migrations/rollback.js"
  },
  "keywords": [
    "food-delivery",
    "api",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "WALID YAHAYA",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "check-disk-space": "^3.4.0",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.1.5",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "5.13.0",
    "winston": "^3.19.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "jest-junit": "16.0.0",
    "mongodb-memory-server": "11.0.1",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
