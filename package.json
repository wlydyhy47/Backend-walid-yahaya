{
  "name": "backend",
  "version": "1.0.0",
  "description": "Food Delivery Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/migrations/migrate.js",
    "migrate:up": "node src/migrations/migrate.js",
    "migrate:down": "node src/migrations/rollback.js",
    "migrate:status": "node src/migrations/migrate.js --status",
    "migrate:create": "node src/migrations/migrate.js --create",
    "migrate:dry-run": "node src/migrations/migrate.js --dry-run",
    "rollback": "node src/migrations/rollback.js",
    "rollback:step": "node src/migrations/rollback.js --steps",
    "rollback:to": "node src/migrations/rollback.js --to",
    "db:seed": "node src/seeds/index.js",
    "db:reset": "node src/scripts/reset-db.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:auth": "jest tests/auth.test.js",
    "test:user": "jest tests/user.test.js",
    "test:restaurant": "jest tests/restaurant.test.js",
    "test:order": "jest tests/order.test.js",
    "test:notification": "jest tests/notification.test.js",
    "test:middleware": "jest tests/middleware.test.js",
    "test:performance": "jest tests/performance.test.js",
    "test:integration": "jest tests/integration.test.js",
    "pretest": "echo '🧪 Running pretest checks...'",
    "posttest": "echo '📊 Tests completed. Generating coverage report...'",
    "lint": "echo '⚠️ Linting is disabled for now'",
    "lint:fix": "echo '⚠️ Linting fix is disabled for now'"
  },
  "keywords": [
    "food-delivery",
    "api",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "WALID YAHAYA",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "check-disk-space": "^3.4.0",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "mongodb": "^7.1.0",
    "mongoose": "^9.1.5",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.12.2",
    "winston": "^3.19.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "bcryptjs": "^3.0.3",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb-memory-server": "^11.0.1",
    "nodemailer": "^8.0.2",
    "nodemon": "^3.1.11",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2"
  }
}
