 *         schema:
 *           type: string
 *     responses:
 *       200:
 *         description: قائمة طلبات المتجر
 */
router.get('/admin/stores/:id/orders', auth, role('admin'), PaginationUtils.validatePaginationParams, orderController.getStoreOrdersById);

module.exports = router;
