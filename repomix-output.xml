          reviewsCount: recentReviews.length,
          unreadNotifications: await require("../models/notification.model").countDocuments({
            user: userId,
            status: 'unread'
          })
        }
      },
      timestamp: new Date()
    };

    // حفظ في الكاش لمدة 5 دقائق
    cache.set(cacheKey, responseData, 300);
    
    res.json(responseData);
