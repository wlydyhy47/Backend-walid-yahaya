 *     tags: [📈 Aggregates]
 *     security:
 *       - bearerAuth: []
 *     responses:
 *       200:
 *         description: إحصائيات اليوم
 */
router.get('/advanced-stats/daily', auth, role('admin'), aggregateController.getDailyAdvancedStats);

/**
