    cache.set(cacheKey, responseData, 300); // 5 دقائق
    
    res.json(responseData);
  } catch (error) {
    console.error("❌ Get notification stats error:", error.message);
    res.status(500).json({
      success: false,
      message: "فشل جلب إحصائيات الإشعارات"
    });
  }
