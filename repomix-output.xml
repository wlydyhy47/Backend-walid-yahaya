 */
exports.getTotalUnreadCount = async (req, res) => {
  try {
    const userId = req.user.id;

    const cacheKey = `chat:unread:total:${userId}`;
    const cachedData = cache.get(cacheKey);

    if (cachedData) {
      return res.json({
