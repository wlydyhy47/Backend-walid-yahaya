    res.json({
      success: true,
      message: `تم ${isActive ? 'تفعيل' : 'تعطيل'} التاجر بنجاح`,
      data: {
        id: vendor._id,
        isActive: vendor.isActive
      }
    });
  } catch (error) {
    console.error("❌ Toggle vendor status error:", error);
    res.status(500).json({
      success: false,
      message: "فشل تغيير حالة التاجر"
    });
  }
};

