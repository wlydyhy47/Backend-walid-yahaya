      { $match: { user: userId, status: "delivered" } },
      { $unwind: "$items" },
      {
        $lookup: {
          from: "items",
          localField: "items.item",
          foreignField: "_id",
          as: "itemDetails",
        },
      },
      { $unwind: "$itemDetails" },
      {
        $group: {
          _id: "$itemDetails.category",
          count: { $sum: 1 },
          totalSpent: { $sum: "$items.price" },
        },
      },
