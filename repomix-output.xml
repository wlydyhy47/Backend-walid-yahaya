        message: "قائمة المشاركين مطلوبة"
      });
    }
    const users = await User.find({ _id: { $in: participantIds } });
    if (users.length !== participantIds.length) {
      return res.status(400).json({
        success: false,
        message: "بعض المستخدمين غير موجودين"
      });
    }
