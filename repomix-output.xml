  const config = REQUIRED_METHODS[controllerName];
  if (!config) {
    console.log(`\n${colorize(`❌ لا يوجد تعريف للـ Controller: ${controllerName}`, 'red')}`);
    return null;
  }
  try {
    const controllers = require('../controllers');
