    // إبطال الكاش
    invalidateConversationCache(conversation._id, [userId]);

    res.status(201).json({
      success: true,
      message: "تم إنشاء محادثة الدعم بنجاح",
      data: {
        conversation: populatedConversation,
        estimatedWaitTime: supportAgent ? "فوري" : "قد يستغرق الرد بعض الوقت"
      }
