      total,
      paginationOptions,
      {
        stats: {
          totalDelivered,
          totalEarnings,
          currentActive,
          byStatus: driverStats.reduce((acc, stat) => {
            acc[stat._id] = {
              count: stat.count,
              earnings: stat.totalEarnings
            };
            return acc;
          }, {})
        }
      }
    );
    res.json(response);
  } catch (error) {
    console.error('❌ Get driver orders error:', error.message);
    res.status(500).json({
      success: false,
      message: 'فشل جلب طلبات المندوب'
    });
  }
};
