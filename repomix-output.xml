      "deleted.isDeleted": false
    })
      .select('content.media type delivery.sentAt')
      .sort({ "delivery.sentAt": -1 })
      .skip(skip)
      .limit(parseInt(limit))
      .lean();
    const total = await Message.countDocuments({
      conversation: conversationId,
      type: "file",
      "deleted.isDeleted": false
    });
    res.json({
      success: true,
