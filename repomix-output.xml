      conversationId,
      messageId,
      deletedBy: userId,
      timestamp: new Date(),
    });

    res.json({
      success: true,
      message: "Message deleted successfully",
      data: {
        messageId,
        deletedBy: userId,
      },
    });
  } catch (error) {
    console.error("❌ Delete message error:", error.message);
    res.status(500).json({
      success: false,
      message: "Failed to delete message",
