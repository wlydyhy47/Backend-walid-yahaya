    // إرسال تحديث عبر Socket.io
    socketService.sendToUser(userId, {
      type: "notification:read",
      data: {
        id: notificationId,
        readAt: new Date()
      }
    });

    res.json({
      success: true,
      message: "تم تحديث حالة الإشعار",
