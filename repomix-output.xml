 */
router.get('/admin/stats/revenue', auth, role('admin'), aggregateController.getAdminRevenueStats);

/**
 * @swagger
 * /aggregate/orders/admin:
 *   get:
 *     summary: جميع الطلبات للمشرف مع pagination
 *     tags: [📈 Aggregates]
 *     security:
 *       - bearerAuth: []
 *     parameters:
 *       - in: query
