        }
      }
    ]);

    const response = PaginationUtils.createPaginationResponse(
      orders,
      total,
      paginationOptions,
      {
        driverStats: driverStats[0] || { totalDelivered: 0, totalEarnings: 0 }
      }
    );

    res.json(response);
