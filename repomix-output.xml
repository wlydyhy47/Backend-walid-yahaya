        .filter(file => /\.(png|ico|svg)$/i.test(file))
        .map(async (file) => {
          const filePath = path.join(iconsDir, file);
          const size = await getFileSize(filePath);
          
          return {
            filename: file,
            url: `/icons/${file}`,
            fullUrl: `${process.env.API_URL || 'http://localhost:3000'}/icons/${file}`,
            type: file.split('.').pop().toLowerCase(),
