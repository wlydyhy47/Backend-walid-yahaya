          order: {
            orderId,
            store: order.store._id,
            driver: order.driver?._id,
            status: "active"
          }
        },
        expiresAt: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000),
        lastActivity: new Date()
      });
