 *   get:
 *     summary: طلبات المستخدم الحالي مع pagination
 *     tags: [📈 Aggregates]
 *     security:
 *       - bearerAuth: []
 *     parameters:
 *       - in: query
 *         name: page
 *         schema:
 *           type: integer
 *       - in: query
 *         name: limit
 *         schema:
 *           type: integer
 *       - in: query
 *         name: status
 *         schema:
 *           type: string
 *       - in: query
 *         name: fromDate
 *         schema:
 *           type: string
 *           format: date
 *       - in: query
 *         name: toDate
 *         schema:
 *           type: string
 *           format: date
 *     responses:
 *       200:
 *         description: قائمة الطلبات
 */
router.get('/orders/me', auth, PaginationUtils.validatePaginationParams, aggregateController.getMyOrdersPaginated);

// ========== 2. مسارات الأدمن فقط ==========

/**
 * @swagger
 * /aggregate/admin/dashboard:
 *   get:
 *     summary: لوحة تحكم المشرف
 *     tags: [📈 Aggregates]
 *     security:
 *       - bearerAuth: []
 *     responses:
 *       200:
