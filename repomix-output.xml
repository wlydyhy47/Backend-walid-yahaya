    .allow('', null),
  
  nutritionalInfo: Joi.alternatives()
    .try(
      Joi.object(),
      Joi.string()
    )
    .optional()
    .allow('', null),
});

/**
 * تحديث المخزون
 */
const updateInventorySchema = Joi.object({
  quantity: Joi.number()
    .integer()
    .min(0)
    .required()
    .messages({
      'number.integer': 'الكمية يجب أن تكون عدداً صحيحاً',
      'number.min': 'الكمية يجب أن تكون 0 أو أكثر',
      'any.required': 'الكمية مطلوبة'
    }),
  
  operation: Joi.string()
    .valid('set', 'add', 'subtract')
    .default('set')
    .messages({
      'any.only': 'العملية يجب أن تكون set, add, أو subtract'
    }),
  
  unit: Joi.string()
    .optional()
    .allow('', null),
  
  lowStockThreshold: Joi.number()
    .integer()
    .min(0)
    .optional()
    .allow('', null)
});

module.exports = {
  createProductSchema,
  updateProductSchema,
  updateInventorySchema
};
