        title: 'الطلب جاهز',
        description: 'الطلب جاهز للاستلام من المتجر',
        timestamp: order.status === 'ready' ? order.updatedAt : null,
        completed: order.status === 'ready' || order.status === 'picked' || order.status === 'delivered'
      },
