 *                   type: boolean
 *                 data:
 *                   type: object
 *                   properties:
 *                     revokedCount:
 *                       type: integer
 *       401:
 *         $ref: '#/components/responses/UnauthorizedError'
 */
router.post("/revoke-all-sessions", auth, authController.revokeAllSessions);

module.exports = router;
