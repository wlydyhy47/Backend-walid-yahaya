        location: updatedUser.location,
        role: updatedUser.role,
        timestamp: new Date()
      });
    }
    res.json({
      success: true,
      message: `You are now ${isOnline ? 'online' : 'offline'}`,
      data: {
        isOnline: updatedUser.isOnline,
        location: updatedUser.location
      }
    });
