 */
router.get('/admin/stats/orders', auth, role('admin'), aggregateController.getAdminOrderStats);

/**
 * @swagger
 * /aggregate/admin/stats/revenue:
 *   get:
 *     summary: إحصائيات الإيرادات للمشرف
