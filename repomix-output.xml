            _id: null,
            total: { $sum: '$totalPrice' },
            avgOrderValue: { $avg: '$totalPrice' },
            maxOrder: { $max: '$totalPrice' },
            minOrder: { $min: '$totalPrice' }
          }
        }
      ]),
      Order.aggregate([
        {
          $match: {
            createdAt: { $gte: startDate },
