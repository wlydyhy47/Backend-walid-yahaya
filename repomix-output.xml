          driver: order.driver._id,
          order: order._id,
          createdAt: { $gte: new Date(Date.now() - 30 * 60 * 1000) }
        })
          .select('location createdAt')
          .sort({ createdAt: 1 })
          .limit(20)
          .lean()
      ]);
