/**
 * @swagger
 * /client/orders:
 *   post:
 *     summary: إنشاء طلب جديد
 *     tags: [👤 Client]
 *     security:
 *       - bearerAuth: []
 *     requestBody:
 *       required: true
 *       content:
 *         application/json:
 *           schema:
 *             $ref: '#/components/schemas/CreateOrderInput'
