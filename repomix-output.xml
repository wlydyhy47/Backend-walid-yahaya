function calculateChange(current, previous) {
  if (!previous || previous === 0) return { percentage: 100, trend: 'up' };
  const change = ((current - previous) / previous) * 100;
  return {
    percentage: Math.abs(change).toFixed(1),
    trend: change >= 0 ? 'up' : 'down'
  };
}
