{
  "tags": [
    {
      "name": "Loyalty",
      "description": "🎁 نظام الولاء والنقاط"
    }
  ],
  "paths": {
    "/loyalty/points": {
      "get": {
        "tags": ["Loyalty"],
        "summary": "الحصول على نقاط الولاء الحالية",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "نقاط الولاء والمستوى",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "current": 1250,
                    "tier": { "name": "silver", "multiplier": 1.2, "color": "#C0C0C0" },
                    "nextTier": { "name": "gold", "pointsNeeded": 750, "progress": 62.5 },
                    "history": { "earned": 2500, "redeemed": 1250 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/loyalty/rewards": {
      "get": {
        "tags": ["Loyalty"],
        "summary": "الحصول على قائمة المكافآت المتاحة",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "قائمة المكافآت",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "available": [
                      { "id": "discount_10", "name": "خصم 10%", "points": 100 },
                      { "id": "free_delivery", "name": "توصيل مجاني", "points": 50 }
                    ],
                    "upcoming": [],
                    "userPoints": 1250
                  }
                }
              }
            }
          }
        }
      }
    },
    "/loyalty/transactions": {
      "get": {
        "tags": ["Loyalty"],
        "summary": "سجل معاملات النقاط",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["earn", "redeem"] } }
        ],
        "responses": {
          "200": {
            "description": "سجل المعاملات",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "transactions": [],
                    "pagination": { "page": 1, "limit": 20, "total": 15 },
                    "stats": { "totalEarned": 2500, "totalRedeemed": 1250 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/loyalty/redeem": {
      "post": {
        "tags": ["Loyalty"],
        "summary": "استبدال النقاط بمكافأة",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount", "rewardId"],
                "properties": {
                  "amount": { "type": "integer", "minimum": 1 },
                  "rewardId": { "type": "string" },
                  "orderId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "تم استبدال النقاط",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": { "newBalance": 1150, "transaction": {} }
                }
              }
            }
          },
          "400": { "description": "نقاط غير كافية" }
        }
      }
    },
    "/loyalty/stats": {
      "get": {
        "tags": ["Loyalty"],
        "summary": "إحصائيات الولاء",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "إحصائيات تفصيلية",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "currentPoints": 1250,
                    "tier": "silver",
                    "memberSince": "2024-01-01T00:00:00.000Z",
                    "monthly": { "Jan": { "earn": 500, "redeem": 0 } }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}