{
  "tags": [
    {
      "name": "Map",
      "description": "🗺️ خدمات الخرائط والتتبع"
    }
  ],
  "paths": {
    "/map/directions": {
      "post": {
        "tags": ["Map"],
        "summary": "حساب المسار بين نقطتين",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["origin", "destination"],
                "properties": {
                  "origin": {
                    "type": "object",
                    "properties": {
                      "latitude": { "type": "number" },
                      "longitude": { "type": "number" }
                    }
                  },
                  "destination": {
                    "type": "object",
                    "properties": {
                      "latitude": { "type": "number" },
                      "longitude": { "type": "number" }
                    }
                  },
                  "profile": { "type": "string", "enum": ["driving", "walking", "cycling"], "default": "driving" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "تم حساب المسار بنجاح",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "distance": 1250,
                    "distanceKm": 1.25,
                    "duration": 540,
                    "durationMinutes": 9,
                    "geometry": {}
                  }
                }
              }
            }
          },
          "400": { "description": "نقطة البداية أو الوجهة غير صالحة" }
        }
      }
    },
    "/map/geocode": {
      "get": {
        "tags": ["Map"],
        "summary": "تحويل العنوان إلى إحداثيات",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "address", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 5 } }
        ],
        "responses": {
          "200": {
            "description": "نتائج البحث",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": [
                    {
                      "placeName": "الرياض، المملكة العربية السعودية",
                      "center": { "latitude": 24.7136, "longitude": 46.6753 }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/map/reverse-geocode": {
      "get": {
        "tags": ["Map"],
        "summary": "تحويل الإحداثيات إلى عنوان",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "latitude", "in": "query", "required": true, "schema": { "type": "number" } },
          { "name": "longitude", "in": "query", "required": true, "schema": { "type": "number" } }
        ],
        "responses": {
          "200": {
            "description": "العنوان المستخرج",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "address": "الرياض، المملكة العربية السعودية",
                    "coordinates": { "latitude": 24.7136, "longitude": 46.6753 }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/map/driver/location": {
      "put": {
        "tags": ["Map"],
        "summary": "تحديث موقع المندوب",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["latitude", "longitude"],
                "properties": {
                  "latitude": { "type": "number" },
                  "longitude": { "type": "number" },
                  "accuracy": { "type": "number" },
                  "heading": { "type": "number" },
                  "speed": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "تم تحديث الموقع بنجاح" },
          "403": { "description": "غير مصرح - هذا المسار للمندوبين فقط" }
        }
      }
    },
    "/map/driver/{driverId}/track": {
      "get": {
        "tags": ["Map"],
        "summary": "تتبع موقع مندوب",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "driverId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "موقع المندوب",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "driver": { "id": "...", "name": "أحمد", "rating": 4.8 },
                    "currentLocation": { "latitude": 24.7136, "longitude": 46.6753 },
                    "history": []
                  }
                }
              }
            }
          },
          "403": { "description": "غير مصرح بتتبع هذا المندوب" },
          "404": { "description": "المندوب غير موجود" }
        }
      }
    },
    "/map/stores": {
      "get": {
        "tags": ["Map"],
        "summary": "الحصول على المتاجر القريبة على الخريطة",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "lat", "in": "query", "required": true, "schema": { "type": "number" } },
          { "name": "lng", "in": "query", "required": true, "schema": { "type": "number" } },
          { "name": "radius", "in": "query", "schema": { "type": "integer", "default": 5000 } },
          { "name": "category", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "المتاجر القريبة",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": { "stores": [], "count": 10 }
                }
              }
            }
          }
        }
      }
    }
  }
}