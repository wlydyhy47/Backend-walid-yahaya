{
  "tags": [
    {
      "name": "Stores",
      "description": "🏪 إدارة المتاجر والمنتجات"
    }
  ],
  "paths": {
    "/stores": {
      "get": {
        "tags": ["Stores"],
        "summary": "الحصول على قائمة المتاجر",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "minRating", "in": "query", "schema": { "type": "number", "minimum": 0, "maximum": 5 } }
        ],
        "responses": {
          "200": {
            "description": "قائمة المتاجر",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": [],
                  "pagination": { "page": 1, "limit": 20, "total": 50 }
                }
              }
            }
          }
        }
      }
    },
    "/stores/{id}": {
      "get": {
        "tags": ["Stores"],
        "summary": "تفاصيل المتجر",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "تفاصيل المتجر مع المنتجات والتقييمات",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "store": {},
                    "products": [],
                    "reviews": [],
                    "categories": []
                  }
                }
              }
            }
          },
          "404": { "description": "المتجر غير موجود" }
        }
      }
    }
  }
}